<script>
    function FinishSample(strEmail, intID, strFlag){
        var LS_URL = "https://apps.jsifurniture.com/finishsamples/";
        var SC_URL = "https://apps.jsifurniture.com/finishsamples/shopcart.aspx/";

        //var LS_URL = "https://jgtestweb.azurewebsites.net/jsifinishInfo/";
        //var SC_URL = "https://jgtestweb.azurewebsites.net/jsifinishInfo/shopcart.aspx/";

  
        var URL = "";
        var CurDat = new Date();
        var intYear = CurDat.getFullYear();
        var intMonth = CurDat.getMonth();
        var intDay = CurDat.getDate();
        var intHour = CurDat.getHours();
        var intMinute = CurDat.getMinutes();
        var intSeconds = CurDat.getSeconds();

        var strDateTime = "" + intYear + intMonth + intDay + intHour + intMinute + intSeconds;

        switch(strFlag){
            case "ls":
                URL = LS_URL;
                break;
            case "sc":
                URL = SC_URL;
                break;
            default:
                URL = LS_URL;
        }

        if (strEmail > " " ){
            URL = URL + "?info=" + strEmail + "~" + intID + "~Df8%$d5qAcDfb" + "~" + strDateTime;
        }
        
        window.open(URL, "_blank");
    }


</script>

